# =============================================================================
# SWITCH — Environment Variables Guide
# =============================================================================
# Copy this file and rename it to .env, then fill in your own values.
# NEVER commit your real .env file to GitHub / GitLab.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE — Frontend (Vite / Browser)
# These are safe to expose in the browser (anon / public keys only).
# Find them in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Your Supabase project reference ID (found in the project URL)
# Example: https://xyzabc.supabase.co  →  xyzabc
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id

# Supabase project URL  (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your_project_id.supabase.co

# Supabase anon/public key  (Project Settings → API → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Storage bucket name for product images (create in Supabase Storage)
VITE_SUPABASE_PRODUCT_IMAGE_BUCKET=products


# -----------------------------------------------------------------------------
# SUPABASE — Backend / Server-side (Vercel API routes)
# ⚠️  NEVER expose these in the browser — server-side only!
# Find them in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Supabase project URL (same as VITE_SUPABASE_URL but used server-side)
SUPABASE_URL=https://your_project_id.supabase.co

# Supabase service role key  (Project Settings → API → service_role secret)
# ⚠️  Has full database access — keep this secret!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# -----------------------------------------------------------------------------
# ADMIN API — Custom Admin Panel Security
# A secret token that protects your /api/admin/* routes.
# Use any strong random string (e.g. generate with: openssl rand -hex 32)
# Set the SAME value in both VITE_ADMIN_API_TOKEN and ADMIN_API_TOKEN.
# -----------------------------------------------------------------------------

# Used by the browser to authenticate admin API calls
VITE_ADMIN_API_TOKEN=your_strong_random_admin_secret_token

# Used by Vercel serverless functions to verify admin requests
ADMIN_API_TOKEN=your_strong_random_admin_secret_token


# -----------------------------------------------------------------------------
# AI / OPENAI — Style Advisor & AI Assistant Features
# Get your API key from: https://platform.openai.com/api-keys
# ⚠️  Keep secret — has billing implications!
# -----------------------------------------------------------------------------

VITE_OPENAI_API_KEY=sk-your_openai_api_key_here


# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# For Vercel:
#   → Go to Project Settings → Environment Variables and add all keys above.
#   → VITE_* keys → Environment: Production, Preview, Development
#   → Server-only keys (no VITE_ prefix) → Environment: Production only
#
# For local development:
#   → Create a file named exactly ".env" in the project root
#   → Copy this file contents and fill in real values
#   → The .env file is already in .gitignore — it will NOT be committed
# =============================================================================
